---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../lib/products";
import { createCustomOrderMessage, createProductMessage } from "../lib/whatsapp";

const categories = [...new Set(products.map((product) => product.category))];
---

<BaseLayout
  title="Cardápio | W.J.F SALGADOS"
  description="Confira nosso cardápio com salgados para festa, churros, salgados grandes e opções sob encomenda."
>
  <section class="bg-gradient-to-br from-amber-100 via-orange-50 to-red-100">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="max-w-3xl">
        <span class="rounded-full bg-orange-100 px-4 py-1 text-sm font-semibold text-orange-700">
          Nosso cardápio
        </span>

        <h1 class="mt-4 text-4xl font-extrabold text-stone-900 md:text-5xl">
          Escolha os salgados ideais para sua festa, evento ou lanche
        </h1>

        <p class="mt-4 text-lg text-stone-700">
          Trabalhamos com opções variadas, encomendas personalizadas e atendimento para São Lourenço da Mata e região.
        </p>
      </div>

      <div class="mt-10 flex flex-wrap gap-3">
        {categories.map((category) => (
          <span class="rounded-full bg-white px-4 py-2 text-sm font-medium text-orange-700 shadow-sm">
            {category}
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-8 md:grid-cols-2 xl:grid-cols-3">
      {products.map((product) => (
        <article class="overflow-hidden rounded-3xl bg-white shadow-md transition hover:-translate-y-1 hover:shadow-xl">
          {product.image ? (
            <img
              src={product.image}
              alt={product.name}
              class="h-56 w-full object-cover"
              loading="lazy"
            />
          ) : (
            <div class="flex h-56 w-full items-center justify-center bg-gradient-to-br from-orange-100 via-amber-50 to-red-100">
              <span class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-orange-600 shadow-sm">
                Imagem do produto
              </span>
            </div>
          )}

          <div class="p-6">
            <span class="inline-block rounded-full bg-orange-100 px-3 py-1 text-sm font-medium text-orange-700">
              {product.category}
            </span>

            <h2 class="mt-4 text-2xl font-bold text-stone-900">
              {product.name}
            </h2>

            <p class="mt-3 text-stone-700">
              {product.description}
            </p>

            <p class="mt-4 font-semibold text-orange-600">
              {product.price}
            </p>

            <a
              href={
                product.custom
                  ? createCustomOrderMessage("um orçamento personalizado")
                  : createProductMessage(product.name)
              }
              target="_blank"
              rel="noopener noreferrer"
              class="mt-5 inline-block rounded-full bg-orange-500 px-5 py-2.5 font-semibold text-white transition hover:bg-orange-600"
            >
              {product.custom ? "Solicitar orçamento" : "Pedir este item"}
            </a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
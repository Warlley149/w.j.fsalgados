---
import BaseLayout from "../layouts/BaseLayout.astro";
import { products } from "../lib/products";
import { createCustomOrderMessage, createProductMessage } from "../lib/whatsapp";

const categories = ["Todos", ...new Set(products.map((product) => product.category))];
const categoryCounts = categories.map((category) => ({
  name: category,
  count:
    category === "Todos"
      ? products.length
      : products.filter((product) => product.category === category).length
}));
---

<BaseLayout
  title="Cardápio | W.J.F SALGADOS"
  description="Confira nosso cardápio com salgados para festa, doces, porções, combos e encomendas personalizadas."
>
  <section class="bg-gradient-to-br from-amber-100 via-orange-50 to-red-100">
    <div class="mx-auto max-w-6xl px-4 py-16">
      <div class="max-w-3xl">
        <span class="rounded-full bg-orange-100 px-4 py-1 text-sm font-semibold text-orange-700">
          Nosso cardápio
        </span>

        <h1 class="mt-4 text-4xl font-extrabold text-stone-900 md:text-5xl">
          Escolha os salgados ideais para sua festa, evento ou lanche
        </h1>

        <p class="mt-4 text-lg text-stone-700">
          Explore categorias, veja os itens mais pedidos, encontre combos para festa e solicite seu pedido com praticidade.
        </p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-[1fr_auto] md:items-center">
        <div class="flex flex-wrap gap-3" id="category-filters">
          {categoryCounts.map((category, index) => (
            <button
              type="button"
              class={`filter-btn inline-flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition ${
                index === 0
                  ? "bg-orange-500 text-white shadow-md"
                  : "bg-white text-orange-700 shadow-sm hover:bg-orange-100"
              }`}
              data-category={category.name}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              <span>{category.name}</span>
              <span
                class={`rounded-full px-2 py-0.5 text-xs ${
                  index === 0
                    ? "bg-white/20 text-white"
                    : "bg-orange-100 text-orange-700"
                }`}
              >
                {category.count}
              </span>
            </button>
          ))}
        </div>

        <div>
          <label for="product-search" class="sr-only">Buscar produto</label>
          <input
            id="product-search"
            type="search"
            placeholder="Buscar por nome do produto"
            class="w-full rounded-2xl border border-orange-200 bg-white px-4 py-3 text-stone-800 outline-none transition placeholder:text-stone-400 focus:border-orange-400 focus:ring-2 focus:ring-orange-200 md:w-80"
          />
        </div>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <div class="mb-8 flex flex-col gap-2 md:flex-row md:items-center md:justify-between">
      <p id="results-text" class="text-sm font-medium text-stone-600">
        Exibindo todos os produtos.
      </p>

      <p class="text-sm text-stone-500">
        Clique em um item para ver mais detalhes.
      </p>
    </div>

    <div
      id="product-grid"
      class="grid gap-8 md:grid-cols-2 xl:grid-cols-3"
    >
      {products.map((product) => (
        <article
          class="product-card group overflow-hidden rounded-3xl bg-white shadow-md transition duration-300 hover:-translate-y-1 hover:shadow-xl"
          data-category={product.category}
          data-name={product.name.toLowerCase()}
        >
          <button
            type="button"
            class="block w-full text-left"
            data-open-modal="true"
            data-product-name={product.name}
            data-product-category={product.category}
            data-product-description={product.description}
            data-product-price={product.price}
            data-product-image={product.image ?? ""}
            data-product-details={product.details ?? ""}
            data-product-serves={product.serves ?? ""}
          >
            <div class="relative overflow-hidden">
              {product.image ? (
                <img
                  src={product.image}
                  alt={product.name}
                  class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-56 w-full items-center justify-center bg-gradient-to-br from-orange-100 via-amber-50 to-red-100">
                  <span class="rounded-full bg-white px-4 py-2 text-sm font-semibold text-orange-600 shadow-sm">
                    Imagem do produto
                  </span>
                </div>
              )}

              <div class="absolute left-4 top-4 flex flex-wrap gap-2">
                <span class="rounded-full bg-white/90 px-3 py-1 text-xs font-semibold text-orange-700 shadow-sm">
                  {product.category}
                </span>

                {product.featured && (
                  <span class="rounded-full bg-orange-500 px-3 py-1 text-xs font-semibold text-white shadow-sm">
                    Mais pedido
                  </span>
                )}

                {product.combo && (
                  <span class="rounded-full bg-stone-900/85 px-3 py-1 text-xs font-semibold text-white shadow-sm">
                    Combo
                  </span>
                )}
              </div>
            </div>

            <div class="p-6">
              <h2 class="text-2xl font-bold text-stone-900">
                {product.name}
              </h2>

              <p class="mt-3 text-stone-700">
                {product.description}
              </p>

              {product.serves && (
                <p class="mt-3 inline-block rounded-full bg-amber-50 px-3 py-1 text-sm font-medium text-amber-700">
                  {product.serves}
                </p>
              )}

              <p class="mt-4 font-semibold text-orange-600">
                {product.price}
              </p>

              <span class="mt-5 inline-flex items-center text-sm font-semibold text-orange-600">
                Ver detalhes
              </span>
            </div>
          </button>

          <div class="px-6 pb-6">
            <a
              href={
                product.custom
                  ? createCustomOrderMessage("um orçamento personalizado")
                  : createProductMessage(product.name)
              }
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block rounded-full bg-orange-500 px-5 py-2.5 font-semibold text-white transition hover:bg-orange-600"
            >
              {product.custom ? "Solicitar orçamento" : "Pedir este item"}
            </a>
          </div>
        </article>
      ))}
    </div>

    <div
      id="empty-state"
      class="hidden rounded-3xl border border-dashed border-orange-300 bg-orange-50 p-10 text-center"
    >
      <h2 class="text-2xl font-bold text-stone-900">Nenhum item encontrado</h2>
      <p class="mt-3 text-stone-700">
        Tente buscar outro nome ou selecionar uma categoria diferente.
      </p>
    </div>
  </section>

  <dialog
     id="product-modal"
     class="product-modal w-[min(92vw,42rem)] rounded-3xl p-0 backdrop:bg-stone-950/70"
     aria-labelledby="modal-title"
    >
    <div class="overflow-hidden rounded-3xl bg-white">
      <div class="relative">
        <img
          id="modal-image"
          src=""
          alt=""
          class="h-72 w-full object-cover"
        />

        <button
          id="close-modal"
          type="button"
          class="absolute right-4 top-4 rounded-full bg-white/90 px-3 py-2 text-sm font-semibold text-stone-900 shadow-md transition hover:bg-white"
          aria-label="Fechar detalhes do produto"
        >
          Fechar
        </button>
      </div>

      <div class="p-6 md:p-8">
        <p
          id="modal-category"
          class="inline-block rounded-full bg-orange-100 px-3 py-1 text-sm font-medium text-orange-700"
        ></p>

        <h2 id="modal-title" class="mt-4 text-3xl font-bold text-stone-900"></h2>

        <p id="modal-description" class="mt-4 text-stone-700"></p>

        <p
          id="modal-serves"
          class="mt-4 hidden rounded-full bg-amber-50 px-3 py-1 text-sm font-medium text-amber-700"
        ></p>

        <p id="modal-details" class="mt-4 text-stone-700"></p>

        <p id="modal-price" class="mt-6 text-lg font-semibold text-orange-600"></p>
      </div>
    </div>
  </dialog>

  <style>
  .product-card {
    opacity: 1;
    transform: translateY(0);
  }

  .product-card.is-hiding {
    opacity: 0;
    transform: translateY(10px);
    pointer-events: none;
  }

  .product-card,
  .product-card img {
    transition:
      opacity 220ms ease,
      transform 220ms ease;
  }

  .product-modal {
    margin: auto;
    border: none;
    max-height: 90vh;
    overflow: hidden;
  }

  .product-modal::backdrop {
    background: rgb(28 25 23 / 0.7);
    backdrop-filter: blur(4px);
  }
</style>

  <script>
    const filterButtons = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
    const productCards = document.querySelectorAll<HTMLElement>(".product-card");
    const resultsText = document.getElementById("results-text");
    const emptyState = document.getElementById("empty-state");
    const searchInput = document.getElementById("product-search") as HTMLInputElement | null;

    const modal = document.getElementById("product-modal") as HTMLDialogElement | null;
    const modalImage = document.getElementById("modal-image") as HTMLImageElement | null;
    const modalCategory = document.getElementById("modal-category");
    const modalTitle = document.getElementById("modal-title");
    const modalDescription = document.getElementById("modal-description");
    const modalServes = document.getElementById("modal-serves");
    const modalDetails = document.getElementById("modal-details");
    const modalPrice = document.getElementById("modal-price");
    const closeModalButton = document.getElementById("close-modal");

    let activeCategory: string = "Todos";
    let activeSearch: string = "";

    function updateFilter(selectedCategory: string, searchTerm: string = activeSearch): void {
      let visibleCount = 0;
      const normalizedSearch = searchTerm.trim().toLowerCase();

      productCards.forEach((card) => {
        const cardCategory = card.getAttribute("data-category") ?? "";
        const cardName = card.getAttribute("data-name") ?? "";

        const matchesCategory =
          selectedCategory === "Todos" || cardCategory === selectedCategory;

        const matchesSearch =
          normalizedSearch === "" || cardName.includes(normalizedSearch);

        const shouldShow = matchesCategory && matchesSearch;

        if (shouldShow) {
          card.classList.remove("hidden", "is-hiding");
          visibleCount++;
        } else {
          card.classList.add("is-hiding");
          window.setTimeout(() => {
            if (card.classList.contains("is-hiding")) {
              card.classList.add("hidden");
            }
          }, 180);
        }
      });

      filterButtons.forEach((button) => {
        const isActive = button.getAttribute("data-category") === selectedCategory;
        const badge = button.querySelector("span:last-child");

        button.setAttribute("aria-pressed", isActive ? "true" : "false");
        button.classList.toggle("bg-orange-500", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle("shadow-md", isActive);
        button.classList.toggle("bg-white", !isActive);
        button.classList.toggle("text-orange-700", !isActive);
        button.classList.toggle("shadow-sm", !isActive);
        button.classList.toggle("hover:bg-orange-100", !isActive);

        if (badge) {
          badge.classList.toggle("bg-white/20", isActive);
          badge.classList.toggle("text-white", isActive);
          badge.classList.toggle("bg-orange-100", !isActive);
          badge.classList.toggle("text-orange-700", !isActive);
        }
      });

      if (resultsText) {
        if (selectedCategory === "Todos" && normalizedSearch === "") {
          resultsText.textContent = "Exibindo todos os produtos.";
        } else if (selectedCategory !== "Todos" && normalizedSearch === "") {
          resultsText.textContent = `Exibindo ${visibleCount} item(ns) da categoria: ${selectedCategory}.`;
        } else {
          resultsText.textContent = `Exibindo ${visibleCount} item(ns) para a busca "${searchTerm}"${selectedCategory !== "Todos" ? ` em ${selectedCategory}` : ""}.`;
        }
      }

      if (emptyState) {
        emptyState.classList.toggle("hidden", visibleCount !== 0);
      }

      activeCategory = selectedCategory;
      activeSearch = searchTerm;
    }

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const category = button.getAttribute("data-category") ?? "Todos";
        updateFilter(category, activeSearch);
      });
    });

    searchInput?.addEventListener("input", (event) => {
      const target = event.target as HTMLInputElement;
      updateFilter(activeCategory, target.value);
    });

    document.querySelectorAll<HTMLElement>("[data-open-modal='true']").forEach((button) => {
      button.addEventListener("click", () => {
        if (!modal) return;

        const name = button.getAttribute("data-product-name") ?? "";
        const category = button.getAttribute("data-product-category") ?? "";
        const description = button.getAttribute("data-product-description") ?? "";
        const image = button.getAttribute("data-product-image") ?? "";
        const details = button.getAttribute("data-product-details") ?? "";
        const serves = button.getAttribute("data-product-serves") ?? "";
        const price = button.getAttribute("data-product-price") ?? "";

        if (modalImage) {
          modalImage.src = image || "/images/placeholder-cardapio.jpg";
          modalImage.alt = name;
        }

        if (modalCategory) modalCategory.textContent = category;
        if (modalTitle) modalTitle.textContent = name;
        if (modalDescription) modalDescription.textContent = description;
        if (modalDetails) modalDetails.textContent = details;
        if (modalPrice) modalPrice.textContent = price;

        if (modalServes) {
          modalServes.textContent = serves;
          modalServes.classList.toggle("hidden", serves === "");
        }

        modal.showModal();
      });
    });

    closeModalButton?.addEventListener("click", () => {
      modal?.close();
    });

    modal?.addEventListener("click", (event) => {
      const rect = modal.getBoundingClientRect();
      const isInDialog =
        rect.top <= event.clientY &&
        event.clientY <= rect.top + rect.height &&
        rect.left <= event.clientX &&
        event.clientX <= rect.left + rect.width;

      if (!isInDialog) {
        modal.close();
      }
    });
  </script>
</BaseLayout>